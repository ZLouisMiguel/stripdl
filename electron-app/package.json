{
  "name": "strip-reader",
  "version": "0.1.0",
  "description": "Webtoon reader powered by strip",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.strip.reader",
    "productName": "Strip",
    "icon": "src/assets/icon",
    "files": [
      "main/**/*",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/strip",
        "to": "strip-cli",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
